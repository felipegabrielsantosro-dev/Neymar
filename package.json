{
    "name": "montanha",
    "version": "1.0.0",
    "main": "main.js",
    "type": "module",
    "private": true,
    "scripts": {
        "start": "electron .",
        "build:win": "electron-builder --win",
        "build:linux": "electron-builder --linux",
        "build:all": "electron-builder --win --linux"
    },
    "build": {
        "appId": "montanha.app",
        "productName": "montanha",
        "copyright": "Copyright © 2026 montanha",
        "directories": {
            "output": "dist"
        },
        "asar": true,
        "asarUnpack": [
            "app/view/**/*",
            "node_modules/nunjucks/**/*"
        ],
        "files": [
            "app/**/*",
            "main.js",
            "package.json",
            "!app/**/*.map",
            "!app/**/test/**"
        ],
        "extraFiles": [
            {
                "from": ".env.production",
                "to": ".env"
            }
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "app/assets/icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "montanha",
            "installerIcon": "app/assets/icon.ico",
            "uninstallerIcon": "app/assets/icon.ico",
            "installerHeaderIcon": "app/assets/icon.ico"
        },
        "linux": {
            "target": [
                {
                    "target": "AppImage",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "deb",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "app/assets/icon.png",
            "category": "Office"
        }
    },
    "devDependencies": {
        "drizzle-kit": "^0.31.9",
        "electron": "^40.8.1",
        "electron-builder": "^25.1.8"
    },
    "dependencies": {
        "@fortawesome/fontawesome-free": "^7.2.0",
        "bootstrap": "^5.3.8",
        "datatables.net-bs5": "^2.3.7",
        "datatables.net-responsive-bs5": "^3.0.8",
        "dotenv": "^17.3.1",
        "inputmask": "^5.0.9",
        "jquery": "^4.0.0",
        "knex": "^3.1.0",
        "nunjucks": "^3.2.4",
        "pg": "^8.20.0",
        "sweetalert2": "^11.26.23"
    }
}
